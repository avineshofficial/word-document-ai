# Root gitignore for word-document-ai

# Python
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.pyclass
.pytest_cache/
.coverage
htmlcov/
venv/
.venv/
env/
ENV/
.python-version
pip-log.txt
pip-delete-this-directory.txt

# Backend specifics
backend/__pycache__/
backend/*.sqlite3
backend/*.db
backend/*.log
backend/.env
backend/.env.*
backend/.venv/
backend/venv/
backend/.python-version
backend/*.pyc
backend/__pycache__/

# Node / JavaScript / TypeScript
node_modules/
pnpm-lock.yaml
yarn.lock
package-lock.json
npm-debug.log*
yarn-debug.log*
yarn-error.log*
lerna-debug.log*

# Frontend specifics
frontend/node_modules/
frontend/.next/
frontend/out/
frontend/dist/
frontend/build/
frontend/.turbo/
frontend/.env
frontend/.env.*
frontend/.cache/
frontend/.parcel-cache/
frontend/.swc/
frontend/.pnp.*
frontend/.pnpjs

# VS Code
.vscode/

# MacOS
.DS_Store

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini

# Logs
*.log

# Ignore Python virtual environment root-level/others
.env
.env.*
*.venv
*.env

# Generated documents, reports, or temporary files
backend/generated_docs/
frontend/.next/
